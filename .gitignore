# ============================================================
# SpeedKalandra .gitignore
# ============================================================
# Keeps personal data (PBs, runs, character info) out of the
# public repository.

# === Personal data (NEVER commit) ===
speedkalandra.ini
speedkalandra_zones.txt
data/personal_bests.ini
data/personal_bests.ini.bak
data/run_state.ini
data/runs/
data/speedkalandra.log
data/zone_totals*.txt

# Defensive variant: ignores EVERYTHING under data/ except the
# zone catalog (required at runtime). If other catalog files are
# added in the future, allow each one explicitly with `!data/<name>`.
data/*
!data/zones.csv

# === Build / dist output ===
SpeedKalandra-dist*/
SpeedKalandra-dist*.zip
*.exe

# === User-generated exports (contain profile/character/PB data) ===
# Ignores everything under exports/. To commit an example file in
# the future, allow it explicitly with `!exports/<name>`.
exports/

# === Legacy / archive (dev-only) ===
_LIXEIRA/
BKP/
debug/
runs/

# === IDE / editor ===
.vscode/
.idea/
*.swp
*~
.vs/

# === OS junk ===
.DS_Store
Thumbs.db
desktop.ini

# === Misc temp / backup ===
*.bak
*.tmp
*.log

# === Game logs (in case the user copied them in for testing) ===
Client.txt
Client*.txt

# === Internal audit notes (dev-only) ===
AUDITORIA-PRODUCAO.md
BACKLOG.md
REFACTOR-ROADMAP.md
speedkalandra_gold_standard_guide.md
speedkalandra_gold_standard_guide_v2.md
speedkalandra_roadmap_10_10.md
speedkalandra_roadmap_padrao_ouro.md

# === Local reference material (dev-only, not for the public repo) ===
# ToS.txt is a local copy of the PoE2 Terms of Use used during
# GSG §18 compliance checks. Kept out of the repo to avoid
# redistributing GGG's copyrighted text.
ToS.txt

# === Experimental scripts (dev-only, never released) ===
# Ad-hoc AHK files in the repo root that are not part of the
# tracker itself — used to validate ideas before extracting them
# into src_v2/.
experiment_*.ahk

# === AI assistant context (dev-only, never released) ===
# CLAUDE.md is a pointer file for AI assistants reading the
# repository between sessions. Not part of the public project.
CLAUDE.md
